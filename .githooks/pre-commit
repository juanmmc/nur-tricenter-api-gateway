#!/usr/bin/env bash
# Pre-commit: formatea y ejecuta tests antes del commit.
# Instalar: ./scripts/install-hooks.sh
set -e

cd "$(git rev-parse --show-toplevel)"

echo "[pre-commit] dotnet format..."
dotnet format NurTricenterApiGateway.sln --verbosity quiet || {
  echo "[pre-commit] dotnet format failed. Aborting commit." >&2
  exit 1
}

echo "[pre-commit] re-staging formatted files..."
git add -u

echo "[pre-commit] dotnet test..."
dotnet test NurTricenterApiGateway.sln --nologo --verbosity quiet || {
  echo "[pre-commit] tests failed. Aborting commit." >&2
  exit 1
}

echo "[pre-commit] OK"
