<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura,json</Format>
          <Exclude>[ApiGateway]ApiGateway.Configuration.Microservices.*,[ApiGateway]ApiGateway.Controllers.WeatherForecastController,[*]*.Program</Exclude>
          <ExcludeByFile>**/Program.cs,**/Dockerfile,**/*.Designer.cs</ExcludeByFile>
          <SkipAutoProps>true</SkipAutoProps>
          <DeterministicReport>true</DeterministicReport>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
