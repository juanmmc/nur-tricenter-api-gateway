# Copy to .env on the VPS and fill in values. Never commit .env.
# Host port the gateway will listen on (mapped to container :8080).
GATEWAY_PORT=5000

ASPNETCORE_ENVIRONMENT=Production

# Downstream microservices (reachable from the gateway container).
PATIENTS_URL=http://207.180.197.169:8080
APPOINTMENTS_URL=http://146.190.116.159:9004
PRODUCTION_URL=http://207.180.197.169:8000
PLANS_URL=http://142.93.120.239:8081
LOGISTICS_URL=http://213.136.90.174:9007
CONTRACTS_URL=http://213.136.90.174:6670

# Keycloak (JWT validation).
KEYCLOAK_AUTHORITY=http://154.38.180.80:8080/realms/group3realm
KEYCLOAK_AUDIENCE=account
KEYCLOAK_REQUIRE_HTTPS_METADATA=false

# Comma-separated list of allowed frontend origins (for CORS).
# Leave empty or set to "*" to allow any origin (request origin is reflected).
CORS_ALLOWED_ORIGINS=*

# ──────────────────────────────────────────────
# Observability (tracing + metrics)
# ──────────────────────────────────────────────
SERVICE_NAME=nur-tricenter-api-gateway
SERVICE_VERSION=1.0.0
TRACING_ENABLED=true
ZIPKIN_ENDPOINT=http://jaeger:9411/api/v2/spans

# Host ports for the observability stack UIs.
JAEGER_UI_PORT=16686
JAEGER_ZIPKIN_PORT=9411
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ──────────────────────────────────────────────
# Service discovery (Consul)
# ──────────────────────────────────────────────
CONSUL_ENABLED=true
CONSUL_HOST=consul
CONSUL_PORT=8500
CONSUL_SCHEME=http
CONSUL_UI_PORT=8500
SERVICE_ID=nur-tricenter-api-gateway
SERVICE_ADDRESS=apigateway
SERVICE_PORT=8080
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=15s
HEALTH_CHECK_TIMEOUT=5s
CONSUL_DEREGISTER_AFTER=1m
