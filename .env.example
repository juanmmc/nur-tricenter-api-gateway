# Copy to .env on the VPS and fill in values. Never commit .env.
# Host port the gateway will listen on (mapped to container :8080).
GATEWAY_PORT=5000

ASPNETCORE_ENVIRONMENT=Production

# Downstream microservices fallback URLs (used only when Consul has no healthy instances).
# When UseDiscovery=true on a microservice, the gateway resolves destinations from Consul
# and these URLs are ignored unless Consul is unreachable.
PATIENTS_URL=http://154.38.180.80:8080
APPOINTMENTS_URL=http://146.190.116.159:9004
PRODUCTION_URL=http://154.38.180.80:8000
PLANS_URL=http://142.93.120.239:8081
LOGISTICS_URL=http://213.136.90.174:9007
CONTRACTS_URL=http://213.136.90.174:6670

# Keycloak (JWT validation).
KEYCLOAK_AUTHORITY=http://154.38.180.80:8080/realms/group3realm
KEYCLOAK_AUDIENCE=account
KEYCLOAK_REQUIRE_HTTPS_METADATA=false

# Comma-separated list of allowed frontend origins (for CORS).
CORS_ALLOWED_ORIGINS=*

# ──────────────────────────────────────────────
# Observability — shared stack hosted by `microservicio-produccion-cocina` on the same VPS.
# Jaeger / Prometheus / Grafana / Loki / Consul are NOT part of this compose anymore.
# ──────────────────────────────────────────────
SERVICE_NAME=nur-tricenter-api-gateway
SERVICE_VERSION=1.0.0
TRACING_ENABLED=true
ZIPKIN_ENDPOINT=http://154.38.180.80:9411/api/v2/spans

# ──────────────────────────────────────────────
# Service discovery (Consul shared in the cocina stack)
# ──────────────────────────────────────────────
CONSUL_ENABLED=true
CONSUL_HOST=154.38.180.80
CONSUL_PORT=8500
CONSUL_SCHEME=http
SERVICE_ID=nur-tricenter-api-gateway
# Address the gateway will publish in Consul. Must be reachable by Consul AND
# by other services that proxy through it. Use the public VPS IP so cocina-Consul
# can run health checks from a different docker network.
SERVICE_ADDRESS=154.38.180.80
SERVICE_PORT=5000
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=15s
HEALTH_CHECK_TIMEOUT=5s
CONSUL_DEREGISTER_AFTER=1m
